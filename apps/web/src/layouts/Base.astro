---
import { fetchGlobal } from "../lib/payload";

interface NavLink {
  label: string;
  url: string;
}

interface FooterLink {
  label: string;
  url: string;
  external?: boolean;
}

interface SiteSettingsData {
  siteName?: string;
  siteDescription?: string;
  navLinks?: NavLink[];
  footerLinks?: FooterLink[];
  copyrightName?: string;
}

interface Props {
  title?: string;
  description?: string;
}

let settings: SiteSettingsData = {};
try {
  settings = await fetchGlobal<SiteSettingsData>("site-settings");
} catch {
  // CMS unavailable — use defaults
}

const siteName = settings.siteName || "Erik Ankrom";
const siteDescription = settings.siteDescription || "Personal website of Erik Ankrom";
const navLinks = settings.navLinks?.length ? settings.navLinks : [
  { label: "About", url: "/about" },
  { label: "Resume", url: "/resume" },
  { label: "Blog", url: "/blog" },
  { label: "Projects", url: "/projects" },
];
const footerLinks = settings.footerLinks?.length ? settings.footerLinks : [
  { label: "GitHub", url: "https://github.com/erikankrom", external: true },
  { label: "LinkedIn", url: "https://linkedin.com/in/erikankrom", external: true },
];
const copyrightName = settings.copyrightName || "Erik Ankrom";

const { title, description } = Astro.props;
const displayTitle = title || siteName;
const pageTitle = displayTitle === siteName ? siteName : `${displayTitle} | ${siteName}`;
const pageDescription = description || siteDescription;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={pageDescription} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class="logo">{siteName}</a>
        <ul>
          {navLinks.map((link) => (
            <li><a href={link.url}>{link.label}</a></li>
          ))}
        </ul>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      {footerLinks.length > 0 && (
        <div class="footer-links">
          {footerLinks.map((link) => (
            <a
              href={link.url}
              {...(link.external ? { target: "_blank", rel: "noopener" } : {})}
            >{link.label}</a>
          ))}
        </div>
      )}
      <p>&copy; {new Date().getFullYear()} {copyrightName}</p>
    </footer>
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --color-bg: #0a0a0a;
    --color-surface: #141414;
    --color-border: #262626;
    --color-text: #ededed;
    --color-text-muted: #a1a1a1;
    --color-accent: #3b82f6;
    --max-width: 720px;
    --font-sans: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
    --font-mono: "SF Mono", "Fira Code", "Fira Mono", Menlo, monospace;
  }

  html {
    font-family: var(--font-sans);
    background: var(--color-bg);
    color: var(--color-text);
    line-height: 1.6;
  }

  a {
    color: var(--color-accent);
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  header {
    border-bottom: 1px solid var(--color-border);
  }

  nav {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    color: var(--color-text);
    font-weight: 600;
    font-size: 1.1rem;
  }

  .logo:hover {
    text-decoration: none;
    color: var(--color-accent);
  }

  nav ul {
    display: flex;
    list-style: none;
    gap: 1.5rem;
  }

  nav a {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  nav a:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  main {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 3rem 1.5rem;
  }

  footer {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2rem 1.5rem;
    border-top: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }

  .footer-links {
    display: flex;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .footer-links a {
    color: var(--color-text-muted);
  }

  .footer-links a:hover {
    color: var(--color-text);
  }
</style>
