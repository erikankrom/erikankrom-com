---
import "../styles/global.css";
import { fetchGlobal } from "../lib/payload";
import { ViewTransitions } from "astro:transitions";

interface NavLink {
  label: string;
  url: string;
}

interface FooterLink {
  label: string;
  url: string;
  external?: boolean;
}

interface SiteSettingsData {
  siteName?: string;
  siteDescription?: string;
  navLinks?: NavLink[];
  footerLinks?: FooterLink[];
  copyrightName?: string;
}

interface Props {
  title?: string;
  description?: string;
}

let settings: SiteSettingsData = {};
try {
  settings = await fetchGlobal<SiteSettingsData>("site-settings");
} catch {
  // CMS unavailable — use defaults
}

const siteName = settings.siteName || "Erik Ankrom";
const siteDescription =
  settings.siteDescription || "Personal website of Erik Ankrom";
const navLinks = settings.navLinks?.length
  ? settings.navLinks
  : [
      { label: "About", url: "/about" },
      { label: "Resume", url: "/resume" },
      { label: "Blog", url: "/blog" },
      { label: "Projects", url: "/projects" },
    ];
const footerLinks = settings.footerLinks?.length
  ? settings.footerLinks
  : [
      {
        label: "GitHub",
        url: "https://github.com/erikankrom",
        external: true,
      },
      {
        label: "LinkedIn",
        url: "https://linkedin.com/in/erikankrom",
        external: true,
      },
    ];
const copyrightName = settings.copyrightName || "Erik Ankrom";

const { title, description } = Astro.props;
const displayTitle = title || siteName;
const pageTitle =
  displayTitle === siteName ? siteName : `${displayTitle} | ${siteName}`;
const pageDescription = description || siteDescription;

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en" class="bg-bg text-text">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={pageDescription} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <title>{pageTitle}</title>
    <ViewTransitions />
  </head>
  <body class="min-h-screen flex flex-col font-sans antialiased leading-relaxed">
    <header
      class="sticky top-0 z-50 border-b border-border bg-bg/80 backdrop-blur-xl"
    >
      <nav class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
        <a
          href="/"
          class="text-text font-semibold text-lg tracking-tight hover:text-accent transition-colors duration-200"
        >
          {siteName}
        </a>
        <ul class="flex items-center gap-1">
          {
            navLinks.map((link) => {
              const isActive =
                currentPath === link.url ||
                (link.url !== "/" && currentPath.startsWith(link.url));
              return (
                <li>
                  <a
                    href={link.url}
                    class:list={[
                      "px-3 py-2 rounded-lg text-sm font-medium transition-all duration-200",
                      isActive
                        ? "text-accent bg-accent-muted"
                        : "text-text-muted hover:text-text hover:bg-surface",
                    ]}
                  >
                    {link.label}
                  </a>
                </li>
              );
            })
          }
        </ul>
      </nav>
    </header>

    <main class="flex-1 max-w-5xl mx-auto px-6 py-12 w-full">
      <slot />
    </main>

    <footer class="border-t border-border">
      <div
        class="max-w-5xl mx-auto px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-4"
      >
        <p class="text-text-muted text-sm">
          &copy; {new Date().getFullYear()}
          {copyrightName}
        </p>
        {
          footerLinks.length > 0 && (
            <div class="flex items-center gap-4">
              {footerLinks.map((link) => (
                <a
                  href={link.url}
                  class="text-text-muted hover:text-text text-sm transition-colors duration-200"
                  {...(link.external
                    ? { target: "_blank", rel: "noopener" }
                    : {})}
                >
                  {link.label}
                </a>
              ))}
            </div>
          )
        }
      </div>
    </footer>
  </body>
</html>
