---
interface Props {
  href?: string;
  class?: string;
}

const { href, class: className } = Astro.props;
const Tag = href ? "a" : "div";
---

<Tag
  href={href}
  class:list={[
    "group block rounded-xl border border-border bg-surface/50 p-5 transition-all duration-300",
    "hover:border-border-hover hover:bg-surface-hover hover:shadow-lg hover:shadow-accent/5",
    href && "no-underline",
    className,
  ]}
>
  <slot />
</Tag>
