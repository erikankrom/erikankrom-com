---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="mb-8">
  <h2
    class="text-xs font-semibold uppercase tracking-widest text-accent mb-2"
  >
    {title}
  </h2>
  {subtitle && <p class="text-text-muted text-sm">{subtitle}</p>}
  <div class="mt-3 h-px bg-gradient-to-r from-accent/40 to-transparent"></div>
</div>
