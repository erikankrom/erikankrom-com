---
import Base from "../layouts/Base.astro";
import Card from "../components/Card.astro";
import SectionHeader from "../components/SectionHeader.astro";
import {
  fetchFromCMS,
  mediaUrl,
  mediaAlt,
  type MediaItem,
} from "../lib/payload";
import { fetchGitHubRepos, type GitHubRepo } from "../lib/github";

interface GalleryImage {
  image: MediaItem;
  caption?: string;
}

interface Project {
  id: string;
  title: string;
  slug: string;
  description?: string;
  banner?: MediaItem;
  gallery?: GalleryImage[];
  url?: string;
  repo?: string;
}

let projects: Project[] = [];
try {
  const res = await fetchFromCMS<Project>("projects", {
    sort: "title",
    limit: "50",
  });
  projects = res.docs;
} catch {
  // CMS unavailable
}

const repos = await fetchGitHubRepos();
const cmsRepoUrls = new Set(projects.map((p) => p.repo).filter(Boolean));
const githubRepos = repos.filter((r) => !cmsRepoUrls.has(r.html_url));

const langColors: Record<string, string> = {
  TypeScript: "#3178c6",
  JavaScript: "#f1e05a",
  Python: "#3572A5",
  Rust: "#dea584",
  Go: "#00ADD8",
  HTML: "#e34c26",
  CSS: "#563d7c",
  Shell: "#89e051",
  Java: "#b07219",
  Ruby: "#701516",
};
---

<Base title="Projects" description="Projects by Erik Ankrom">
  <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-text mb-2">
    Projects
  </h1>
  <p class="text-text-muted mb-10">Things I've built and contributed to.</p>

  {
    projects.length > 0 && (
      <div class="grid gap-6 md:grid-cols-2 mb-16">
        {projects.map((project) => (
          <div class="group rounded-xl border border-border bg-surface/50 overflow-hidden transition-all duration-300 hover:border-border-hover hover:shadow-lg hover:shadow-accent/5">
            {mediaUrl(project.banner) && (
              <img
                src={mediaUrl(project.banner)!}
                alt={mediaAlt(project.banner)}
                class="w-full h-48 object-cover transition-transform duration-500 group-hover:scale-[1.02]"
              />
            )}
            <div class="p-5">
              <h2 class="text-lg font-semibold text-text group-hover:text-accent transition-colors duration-200">
                {project.title}
              </h2>
              {project.description && (
                <p class="text-sm text-text-muted mt-2 leading-relaxed">
                  {project.description}
                </p>
              )}

              {project.gallery && project.gallery.length > 0 && (
                <div class="grid grid-cols-3 gap-2 mt-4">
                  {project.gallery.slice(0, 3).map((item) => (
                    <figure>
                      <img
                        src={mediaUrl(item.image)!}
                        alt={mediaAlt(item.image)}
                        loading="lazy"
                        class="w-full aspect-square object-cover rounded-lg border border-border"
                      />
                    </figure>
                  ))}
                </div>
              )}

              <div class="flex items-center gap-3 mt-4 pt-4 border-t border-border">
                {project.url && (
                  <a
                    href={project.url}
                    target="_blank"
                    rel="noopener"
                    class="inline-flex items-center gap-1.5 text-xs font-medium text-accent hover:text-accent-hover transition-colors duration-200"
                  >
                    <svg
                      class="w-3.5 h-3.5"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"
                      />
                    </svg>
                    Live
                  </a>
                )}
                {project.repo && (
                  <a
                    href={project.repo}
                    target="_blank"
                    rel="noopener"
                    class="inline-flex items-center gap-1.5 text-xs font-medium text-text-muted hover:text-text transition-colors duration-200"
                  >
                    <svg
                      class="w-3.5 h-3.5"
                      fill="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                    </svg>
                    Source
                  </a>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    )
  }

  {
    projects.length === 0 && (
      <p class="text-text-muted mb-16">Projects coming soon.</p>
    )
  }

  {
    githubRepos.length > 0 && (
      <section>
        <SectionHeader
          title="Open Source"
          subtitle="GitHub repositories and contributions"
        />
        <div class="grid gap-3 md:grid-cols-2">
          {githubRepos.map((repo) => (
            <a
              href={repo.html_url}
              target="_blank"
              rel="noopener"
              class="group block rounded-xl border border-border bg-surface/50 p-4 transition-all duration-300 hover:border-border-hover hover:bg-surface-hover no-underline"
            >
              <div class="flex items-start justify-between gap-3">
                <h3 class="font-semibold text-sm text-text group-hover:text-accent transition-colors duration-200 truncate">
                  {repo.name}
                </h3>
                {repo.stargazers_count > 0 && (
                  <span class="flex items-center gap-1 text-xs text-text-muted flex-shrink-0">
                    <svg
                      class="w-3.5 h-3.5"
                      fill="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                    </svg>
                    {repo.stargazers_count}
                  </span>
                )}
              </div>
              {repo.description && (
                <p class="text-xs text-text-muted mt-1.5 line-clamp-2">
                  {repo.description}
                </p>
              )}
              {repo.language && (
                <div class="flex items-center gap-1.5 mt-3">
                  <span
                    class="w-2.5 h-2.5 rounded-full flex-shrink-0"
                    style={`background-color: ${langColors[repo.language] || "#888"}`}
                  />
                  <span class="text-xs text-text-muted">{repo.language}</span>
                </div>
              )}
            </a>
          ))}
        </div>
      </section>
    )
  }
</Base>
