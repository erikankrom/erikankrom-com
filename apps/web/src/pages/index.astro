---
import Base from "../layouts/Base.astro";
---

<Base>
  <section class="hero">
    <p class="tagline">Software engineer, builder, thinker.</p>
    <div class="links">
      <a href="/about">About me</a>
      <a href="/blog">Blog</a>
      <a href="/projects">Projects</a>
    </div>
  </section>
</Base>

<style>
  .hero {
    padding: 4rem 0;
  }

  .tagline {
    font-size: 1.5rem;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }

  .links {
    display: flex;
    gap: 1rem;
  }

  .links a {
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    transition: all 0.15s;
  }

  .links a:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    text-decoration: none;
  }
</style>
