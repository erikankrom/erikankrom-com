---
import Base from "../layouts/Base.astro";
import { fetchGlobal } from "../lib/payload";

interface HomepageLink {
  label: string;
  url: string;
}

interface HomepageData {
  tagline?: string;
  links?: HomepageLink[];
}

let homepage: HomepageData = {};
try {
  homepage = await fetchGlobal<HomepageData>("homepage");
} catch {
  // CMS unavailable — use defaults
}

const tagline = homepage.tagline || "Software engineer, builder, thinker.";
const links = homepage.links?.length ? homepage.links : [
  { label: "About me", url: "/about" },
  { label: "Blog", url: "/blog" },
  { label: "Projects", url: "/projects" },
];
---

<Base>
  <section class="hero">
    <p class="tagline">{tagline}</p>
    <div class="links">
      {links.map((link) => (
        <a href={link.url}>{link.label}</a>
      ))}
    </div>
  </section>
</Base>

<style>
  .hero {
    padding: 4rem 0;
  }

  .tagline {
    font-size: 1.5rem;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }

  .links {
    display: flex;
    gap: 1rem;
  }

  .links a {
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    transition: all 0.15s;
  }

  .links a:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    text-decoration: none;
  }
</style>
