---
import Base from "../layouts/Base.astro";
import SectionHeader from "../components/SectionHeader.astro";
import SkillTag from "../components/SkillTag.astro";
import { fetchGlobal } from "../lib/payload";

interface Highlight {
  text: string;
}

interface Experience {
  company: string;
  role: string;
  url?: string;
  startDate: string;
  endDate?: string;
  description?: string;
  highlights?: Highlight[];
}

interface Education {
  institution: string;
  degree: string;
  startDate?: string;
  endDate?: string;
  description?: string;
}

interface SkillCategory {
  category: string;
  items?: { name: string }[];
}

interface Certification {
  name: string;
  issuer?: string;
  date?: string;
  url?: string;
}

interface ResumeData {
  headline?: string;
  summary?: string;
  experience?: Experience[];
  education?: Education[];
  skills?: SkillCategory[];
  certifications?: Certification[];
}

let resume: ResumeData = {};
try {
  resume = await fetchGlobal<ResumeData>("resume");
} catch {
  // CMS unavailable
}
---

<Base title="Resume" description="Resume of Erik Ankrom">
  <div class="max-w-3xl">
    <!-- Header -->
    <div class="mb-10">
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-text">
        Resume
      </h1>
      {
        resume.headline && (
          <p class="mt-2 text-lg text-text-muted">{resume.headline}</p>
        )
      }
    </div>

    {
      resume.summary && (
        <p class="text-text-secondary leading-relaxed text-lg mb-12 border-l-2 border-accent/40 pl-5">
          {resume.summary}
        </p>
      )
    }

    <!-- Experience -->
    {
      resume.experience && resume.experience.length > 0 && (
        <section class="mb-14">
          <SectionHeader title="Experience" />
          <div class="relative">
            {/* Timeline line */}
            <div class="absolute left-[7px] top-2 bottom-2 w-px bg-border" />

            <div class="space-y-8">
              {resume.experience.map((job) => (
                <div class="relative pl-8">
                  {/* Timeline dot */}
                  <div class="absolute left-0 top-2 w-[15px] h-[15px] rounded-full border-2 border-accent bg-bg z-10" />

                  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1">
                    <div>
                      <h3 class="font-semibold text-text">{job.role}</h3>
                      <p class="text-sm text-text-muted">
                        {job.url ? (
                          <a
                            href={job.url}
                            target="_blank"
                            rel="noopener"
                            class="text-accent hover:text-accent-hover transition-colors duration-200"
                          >
                            {job.company}
                          </a>
                        ) : (
                          job.company
                        )}
                      </p>
                    </div>
                    <span class="text-xs text-text-muted font-mono whitespace-nowrap flex-shrink-0">
                      {job.startDate} &mdash; {job.endDate || "Present"}
                    </span>
                  </div>

                  {job.description && (
                    <p class="text-sm text-text-muted mt-2 leading-relaxed">
                      {job.description}
                    </p>
                  )}

                  {job.highlights && job.highlights.length > 0 && (
                    <ul class="mt-3 space-y-1.5">
                      {job.highlights.map((h) => (
                        <li class="flex items-start gap-2 text-sm text-text-muted">
                          <span class="text-accent mt-1.5 flex-shrink-0">
                            <svg
                              class="w-3 h-3"
                              fill="currentColor"
                              viewBox="0 0 24 24"
                            >
                              <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" />
                            </svg>
                          </span>
                          <span>{h.text}</span>
                        </li>
                      ))}
                    </ul>
                  )}
                </div>
              ))}
            </div>
          </div>
        </section>
      )
    }

    <!-- Education -->
    {
      resume.education && resume.education.length > 0 && (
        <section class="mb-14">
          <SectionHeader title="Education" />
          <div class="relative">
            <div class="absolute left-[7px] top-2 bottom-2 w-px bg-border" />
            <div class="space-y-6">
              {resume.education.map((edu) => (
                <div class="relative pl-8">
                  <div class="absolute left-0 top-2 w-[15px] h-[15px] rounded-full border-2 border-accent bg-bg z-10" />

                  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1">
                    <div>
                      <h3 class="font-semibold text-text">{edu.degree}</h3>
                      <p class="text-sm text-text-muted">{edu.institution}</p>
                    </div>
                    {(edu.startDate || edu.endDate) && (
                      <span class="text-xs text-text-muted font-mono whitespace-nowrap flex-shrink-0">
                        {edu.startDate}
                        {edu.endDate && <> &mdash; {edu.endDate}</>}
                      </span>
                    )}
                  </div>

                  {edu.description && (
                    <p class="text-sm text-text-muted mt-2 leading-relaxed">
                      {edu.description}
                    </p>
                  )}
                </div>
              ))}
            </div>
          </div>
        </section>
      )
    }

    <!-- Skills -->
    {
      resume.skills && resume.skills.length > 0 && (
        <section class="mb-14">
          <SectionHeader title="Skills" />
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            {resume.skills.map((cat) => (
              <div class="rounded-xl border border-border bg-surface/50 p-4">
                <h3 class="text-sm font-semibold text-text mb-3">
                  {cat.category}
                </h3>
                {cat.items && cat.items.length > 0 && (
                  <div class="flex flex-wrap gap-2">
                    {cat.items.map((item) => (
                      <SkillTag label={item.name} />
                    ))}
                  </div>
                )}
              </div>
            ))}
          </div>
        </section>
      )
    }

    <!-- Certifications -->
    {
      resume.certifications && resume.certifications.length > 0 && (
        <section class="mb-14">
          <SectionHeader title="Certifications" />
          <div class="grid gap-3">
            {resume.certifications.map((cert) => (
              <div class="flex items-center justify-between gap-4 rounded-xl border border-border bg-surface/50 p-4">
                <div>
                  <h3 class="font-semibold text-sm text-text">
                    {cert.url ? (
                      <a
                        href={cert.url}
                        target="_blank"
                        rel="noopener"
                        class="hover:text-accent transition-colors duration-200"
                      >
                        {cert.name}
                      </a>
                    ) : (
                      cert.name
                    )}
                  </h3>
                  {cert.issuer && (
                    <p class="text-xs text-text-muted mt-0.5">{cert.issuer}</p>
                  )}
                </div>
                {cert.date && (
                  <span class="text-xs text-text-muted font-mono flex-shrink-0">
                    {cert.date}
                  </span>
                )}
              </div>
            ))}
          </div>
        </section>
      )
    }

    {
      !resume.experience?.length &&
        !resume.education?.length &&
        !resume.skills?.length && (
          <div class="text-center py-16">
            <p class="text-text-muted text-lg">Resume details coming soon.</p>
          </div>
        )
    }
  </div>
</Base>
