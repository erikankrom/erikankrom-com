---
import Base from "../layouts/Base.astro";
import { fetchGitHubProfile } from "../lib/github";

const profile = await fetchGitHubProfile();
---

<Base title="About" description="About Erik Ankrom">
  <div class="max-w-2xl">
    <div class="flex items-start gap-6 mb-10">
      {
        profile?.avatar_url && (
          <img
            src={profile.avatar_url}
            alt={profile.name || "Erik Ankrom"}
            class="w-24 h-24 rounded-2xl border-2 border-border shadow-lg shadow-accent/10 flex-shrink-0"
          />
        )
      }
      <div>
        <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-text">
          About
        </h1>
        {
          profile?.bio && (
            <p class="mt-2 text-text-muted text-lg">{profile.bio}</p>
          )
        }
      </div>
    </div>

    <div class="space-y-6 text-text-secondary leading-relaxed text-lg">
      <p>
        Welcome to my corner of the internet. I'm Erik Ankrom — a software
        engineer who enjoys building things that matter.
      </p>
      <p>
        This site is built with <a
          href="https://astro.build"
          class="text-accent hover:text-accent-hover transition-colors duration-200 underline decoration-accent/30 underline-offset-2 hover:decoration-accent"
          target="_blank"
          rel="noopener">Astro</a
        >, powered by <a
          href="https://payloadcms.com"
          class="text-accent hover:text-accent-hover transition-colors duration-200 underline decoration-accent/30 underline-offset-2 hover:decoration-accent"
          target="_blank"
          rel="noopener">Payload CMS</a
        >, and deployed on <a
          href="https://vercel.com"
          class="text-accent hover:text-accent-hover transition-colors duration-200 underline decoration-accent/30 underline-offset-2 hover:decoration-accent"
          target="_blank"
          rel="noopener">Vercel</a
        >.
      </p>
    </div>

    {
      profile && (
        <div class="mt-12 grid grid-cols-2 sm:grid-cols-3 gap-4">
          <div class="rounded-xl border border-border bg-surface/50 p-4 text-center">
            <p class="text-2xl font-bold text-text">
              {profile.public_repos}
            </p>
            <p class="text-xs text-text-muted mt-1 uppercase tracking-wide">
              Repositories
            </p>
          </div>
          <div class="rounded-xl border border-border bg-surface/50 p-4 text-center">
            <p class="text-2xl font-bold text-text">{profile.followers}</p>
            <p class="text-xs text-text-muted mt-1 uppercase tracking-wide">
              Followers
            </p>
          </div>
          <div class="rounded-xl border border-border bg-surface/50 p-4 text-center col-span-2 sm:col-span-1">
            <a
              href={profile.html_url}
              target="_blank"
              rel="noopener"
              class="text-accent hover:text-accent-hover transition-colors duration-200 text-sm font-medium"
            >
              View GitHub Profile &rarr;
            </a>
            <p class="text-xs text-text-muted mt-1">@{profile.login}</p>
          </div>
        </div>
      )
    }
  </div>
</Base>
