---
import Base from "../../layouts/Base.astro";
import { fetchFromCMS } from "../../lib/payload";

interface Post {
  id: string;
  title: string;
  slug: string;
  excerpt?: string;
  publishedAt?: string;
}

let posts: Post[] = [];
try {
  const res = await fetchFromCMS<Post>("posts", {
    sort: "-publishedAt",
    limit: "20",
  });
  posts = res.docs;
} catch {
  // CMS unavailable — render empty state
}
---

<Base title="Blog" description="Blog posts by Erik Ankrom">
  <h1>Blog</h1>
  {
    posts.length > 0 ? (
      <ul class="posts">
        {posts.map((post) => (
          <li>
            <a href={`/blog/${post.slug}`}>
              <span class="title">{post.title}</span>
              {post.publishedAt && (
                <time datetime={post.publishedAt}>
                  {new Date(post.publishedAt).toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "short",
                    day: "numeric",
                  })}
                </time>
              )}
            </a>
            {post.excerpt && <p class="excerpt">{post.excerpt}</p>}
          </li>
        ))}
      </ul>
    ) : (
      <p class="empty">No posts yet. Check back soon.</p>
    )
  }
</Base>

<style>
  h1 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 2rem;
  }

  .posts {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .posts a {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    color: var(--color-text);
  }

  .posts a:hover .title {
    color: var(--color-accent);
  }

  .posts a:hover {
    text-decoration: none;
  }

  .title {
    font-weight: 500;
    transition: color 0.15s;
  }

  time {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    white-space: nowrap;
    font-family: var(--font-mono);
  }

  .excerpt {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-top: 0.25rem;
  }

  .empty {
    color: var(--color-text-muted);
  }
</style>
