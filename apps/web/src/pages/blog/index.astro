---
import Base from "../../layouts/Base.astro";
import Card from "../../components/Card.astro";
import { fetchFromCMS, mediaUrl, mediaAlt, type MediaItem } from "../../lib/payload";

interface Post {
  id: string;
  title: string;
  slug: string;
  excerpt?: string;
  publishedAt?: string;
  banner?: MediaItem;
}

let posts: Post[] = [];
try {
  const res = await fetchFromCMS<Post>("posts", {
    sort: "-publishedAt",
    limit: "20",
  });
  posts = res.docs;
} catch {
  // CMS unavailable
}
---

<Base title="Blog" description="Blog posts by Erik Ankrom">
  <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-text mb-2">
    Blog
  </h1>
  <p class="text-text-muted mb-10">Thoughts, tutorials, and things I've learned.</p>

  {
    posts.length > 0 ? (
      <div class="space-y-4">
        {posts.map((post) => (
          <Card href={`/blog/${post.slug}`} class="flex flex-col sm:flex-row gap-4">
            {mediaUrl(post.banner) && (
              <img
                src={mediaUrl(post.banner)!}
                alt={mediaAlt(post.banner)}
                class="w-full sm:w-44 h-32 sm:h-auto object-cover rounded-lg flex-shrink-0"
              />
            )}
            <div class="flex-1 min-w-0">
              <div class="flex items-start justify-between gap-4">
                <h2 class="font-semibold text-text group-hover:text-accent transition-colors duration-200">
                  {post.title}
                </h2>
                {post.publishedAt && (
                  <time
                    datetime={post.publishedAt}
                    class="text-xs text-text-muted font-mono whitespace-nowrap flex-shrink-0 mt-1"
                  >
                    {new Date(post.publishedAt).toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "short",
                      day: "numeric",
                    })}
                  </time>
                )}
              </div>
              {post.excerpt && (
                <p class="text-sm text-text-muted mt-2 line-clamp-2 leading-relaxed">
                  {post.excerpt}
                </p>
              )}
            </div>
          </Card>
        ))}
      </div>
    ) : (
      <div class="text-center py-16">
        <p class="text-text-muted text-lg">No posts yet. Check back soon.</p>
      </div>
    )
  }
</Base>
